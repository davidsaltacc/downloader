<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" 
        d:DesignWidth="400" d:DesignHeight="300"
        MinWidth="400" MinHeight="300"
        Width="400" Height="300"
        x:Class="Downloader.MainWindow"
        Title="downloader"
		ExtendClientAreaToDecorationsHint="True"
		TransparencyLevelHint="AcrylicBlur"
        Background="Transparent"
		WindowStartupLocation="CenterScreen"
        RenderOptions.TextRenderingMode="Antialias">
    <Grid RowDefinitions="30,*">
		
        <Grid ColumnDefinitions="Auto,*" IsHitTestVisible="False" Background="#bf000000">
			<Image x:Name="TitleBarIcon" Grid.Column="0" VerticalAlignment="Center" Width="18" Margin="5,0,5,0" RenderOptions.BitmapInterpolationMode="HighQuality" />
			<TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="12">Downloader</TextBlock>
		</Grid>

        <Border Grid.Row="1" Padding="10" Background="#7f101010">
            <StackPanel>
                <TextBox Watermark="Input URL" x:Name="DownloadURLBox"></TextBox>
                <Button Click="StartDownload_Click">Start Downloading</Button>
                <TextBlock x:Name="StatusText"></TextBlock>
            </StackPanel>
        </Border>

    </Grid>
</Window>
